---
layout: default
---

<article class="blog-post">
  <%
    ordered_posts = collections.posts.resources.sort_by { |post| post.data.date }.reverse
    current_index = ordered_posts.index { |post| post.relative_url == resource.relative_url }
    previous_post = current_index && current_index.positive? ? ordered_posts[current_index - 1] : nil
    next_post = current_index && current_index < ordered_posts.length - 1 ? ordered_posts[current_index + 1] : nil
  %>

  <% if data.heroImage %>
    <div class="hero-image">
      <img width="1020" height="510" src="<%= data.heroImage %>" alt="<%= data.title %>" loading="lazy" decoding="async">
    </div>
  <% end %>

  <div class="prose">
    <div class="title">
      <div class="date">
        <%= render "format_date", date: data.date %>
      </div>
      <h1><%= data.title %></h1>
      <% if previous_post || next_post %>
        <nav class="post-neighbors" aria-label="前後の記事">
          <% if previous_post %>
            <a href="<%= previous_post.relative_url %>" rel="prev" class="neighbor neighbor-prev"><%= previous_post.data.title %></a>
          <% else %>
            <span class="neighbor neighbor-prev" aria-hidden="true"></span>
          <% end %>

          <span class="separator" aria-hidden="true">|</span>

          <% if next_post %>
            <a href="<%= next_post.relative_url %>" rel="next" class="neighbor neighbor-next"><%= next_post.data.title %></a>
          <% else %>
            <span class="neighbor neighbor-next" aria-hidden="true"></span>
          <% end %>
        </nav>
      <% end %>
      <hr>
    </div>

    <%= yield %>

    <div class="share-buttons">
      <% page_url = absolute_url(resource.relative_url) %>
      <% encoded_url = CGI.escape(page_url) %>
      <% encoded_title = CGI.escape(data.title.to_s) %>
      <% Array(site.metadata.share_buttons).each do |button| %>
        <%
          url = case button.name
                when "hatena" then "#{button.base_url}#{page_url}"
                when "x" then "#{button.base_url}?url=#{encoded_url}&text=#{encoded_title}"
                end
        %>
        <a href="<%= url %>" target="_blank" rel="noopener" aria-label="<%= button.aria_label %>" class="share-button <%= button.name %>-button">
          <%= svg_icon(button.icon) %>
        </a>
      <% end %>
    </div>

    <%= render "comment" %>
  </div>
</article>
