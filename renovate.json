{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Tokyo",
  "schedule": ["* 6-11 * * 0"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 6-11 * * 0"]
  },
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "groupName": "weekly npm dependencies"
    },
    {
      "matchDatasources": ["rubygems"],
      "groupName": "weekly ruby gems"
    },
    {
      "matchDepNames": ["node"],
      "groupName": "weekly node runtime"
    },
    {
      "matchDepNames": ["ruby"],
      "groupName": "weekly ruby runtime"
    },
    {
      "matchPackageNames": ["jdx/hk"],
      "groupName": "weekly hk"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.node-version$"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.ruby-version$"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"],
      "depNameTemplate": "ruby",
      "datasourceTemplate": "ruby-version",
      "versioningTemplate": "ruby"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)hk\\.pkl$"],
      "matchStrings": [
        "v(?<currentValue>\\d+\\.\\d+\\.\\d+)/hk@",
        "hk@(?<currentValue>\\d+\\.\\d+\\.\\d+)#"
      ],
      "depNameTemplate": "jdx/hk",
      "datasourceTemplate": "github-releases"
    }
  ]
}
